      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst creacion = new Date(item.timestamp_creacion);\nconst ahora = new Date();\nconst horas = (ahora - creacion) / (1000 * 60 * 60);\n\nif (horas < 24) {\n  return [{\n    json: {\n      ...item,\n      tipo_duplicado: 'duplicado_real',\n      horas_desde_creacion: horas,\n      accion: 'ignorar'\n    }\n  }];\n} else {\n  return [{\n    json: {\n      ...item,\n      tipo_duplicado: 'lead_reactivado',\n      horas_desde_creacion: horas,\n      dias_desde_creacion: Math.floor(horas / 24),\n      accion: 'procesar'\n    }\n  }];\n}"
