    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH upsert AS (\n  INSERT INTO leads (nome, cognome, email, azienda, servizio, messaggio, timestamp_roma, status)\n  VALUES (\n    '{{ $json.body.nome }}',\n    '{{ $json.body.cognome }}',\n    '{{ $json.body.email }}',\n    '{{ $json.body.azienda }}',\n    '{{ $json.body.servizio }}',\n    '{{ $json.body.messaggio }}',\n    '{{ $json.body.timestamp_roma }}',\n    'pendiente'\n  )\n  ON CONFLICT (email, servizio) DO NOTHING\n  RETURNING id, timestamp_creacion, TRUE AS es_nuevo\n)\nSELECT id, timestamp_creacion, es_nuevo FROM upsert\nUNION ALL\nSELECT id, timestamp_creacion, FALSE AS es_nuevo\nFROM leads\nWHERE email = '{{ $json.body.email }}' AND servizio = '{{ $json.body.servizio }}'\n  AND (SELECT COUNT(*) FROM upsert) = 0",
        "options": {
          "queryReplacement": "="
        }
      },
