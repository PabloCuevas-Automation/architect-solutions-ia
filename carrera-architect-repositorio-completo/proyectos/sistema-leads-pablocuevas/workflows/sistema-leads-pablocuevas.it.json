      ],
      "id": "d71bbdad-5002-4b34-9d45-87d8a3dc64e6",
      "name": "HTTP Abstract (email)",
      "credentials": {
        "httpHeaderAuth": {
          "id": "X6sB6X6rce9kLXt5",
          "name": "Abstract Email Reputation (Header)"
        },
        "httpQueryAuth": {
          "id": "oWoqC54hJAhUMZnu",
          "name": "Abstract Email Reputation (Query)"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const lead = $('procesador-body1').item.json;\n  const abstract = item.json;\n\n  // Fallback si Abstract falló\n  const abstractFallo = !abstract.email_deliverability;\n\n  const entregable = abstractFallo ? null : abstract.email_deliverability.status === \"deliverable\";\n  const esEmailLibre = abstractFallo ? null : abstract.email_quality.is_free_email;\n  const esDesechable = abstractFallo ? null : abstract.email_quality.is_disposable;\n  const nivelRiesgo = abstractFallo ? \"desconocido\" : abstract.email_risk.address_risk_status;\n  const tipoCuenta = abstractFallo ? \"desconocido\" : (abstract.email_sender.organization_name === null && esEmailLibre ? \"personal\" : \"comercial\");\n  \n  let accion, razon;\n\n  if (!abstractFallo && (esDesechable || !entregable || nivelRiesgo === \"high\")) {\n    accion = \"descartar\";\n    razon = esDesechable ? \"email desechable\" : !entregable ? \"email no entregable\" : \"riesgo alto detectado\";\n  } else if (abstractFallo) {\n    accion = \"revisar_manualmente\";\n    razon = \"enriquecimiento no disponible — revisar manualmente\";\n  } else if (nivelRiesgo === \"medium\" || esEmailLibre) {\n    accion = \"revisar_manualmente\";\n    razon = nivelRiesgo === \"medium\" ? \"riesgo medio detectado\" : \"cuenta personal con email libre\";\n  } else {\n    accion = \"procesar\";\n    razon = \"email corporativo verificado, riesgo bajo\";\n  }\n\n  const prioridad = \n  abstract.accion_recomendada === \"descartar\" ? \"baja\" :\n  esEmailLibre ? \"media\" :\n  nivelRiesgo === \"low\" ? \"alta\" : \"media\";\n\n  return {\n    json: {\n      nome: lead.nome,\n      cognome: lead.cognome,\n      email: lead.email,\n      azienda: lead.azienda,\n      servizio: lead.servizio,\n      messaggio: lead.messaggio,\n      timestamp_roma: lead.timestamp_roma,\n      procesado: lead.procesado,\n      tipoCuenta,\n      nivelRiesgo,\n      esEmailLibre,\n      esDesechable,\n      abstract_status: abstract.email_deliverability?.status,\n      abstract_smtp_valid: abstract.email_deliverability?.is_smtp_valid,\n      abstract_live_site: abstract.email_domain?.is_live_site,\n      accion_recomendada: accion,\n      razon,\n      prioridad\n    }\n  };\n});"
      },
