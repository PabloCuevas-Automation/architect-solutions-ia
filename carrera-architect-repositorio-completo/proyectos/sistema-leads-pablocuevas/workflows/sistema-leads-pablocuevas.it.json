    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const d = item.json;\n\n  // Señales de entrada\n  const esDesechable = d.esDesechable === true;\n  const esRiesgoAlto = d.nivelRiesgo === \"high\";\n  const esEmailCorporativo = d.esEmailLibre === false;\n  const tieneEmpresa = d.azienda && d.azienda.trim() !== \"\";\n\n  // Lógica de decisión\n  let accion, razon;\n\n   if (esDesechable || esRiesgoAlto) {\n    accion = \"descartar\";\n    razon = esDesechable ? \"email desechable\" : \"riesgo alto detectado por Abstract\";\n} else if (esEmailCorporativo && tieneEmpresa && d.abstract_live_site !== null) {\n    accion = \"Procesar\";\n    razon = \"Email corporativo con empresa declarada\";\n} else {\n    accion = \"Revisar manualmente\";\n    razon = d.abstract_live_site === null \n        ? \"Dominio no verificable por Abstract\" \n        : \"Confianza insuficiente para decisión automática\";\n}\n\n  return {\n    json: {\n      ...item.json,\n      nivel_resolucion: \"nivel2\",\n      accion_nivel2: accion,\n      razon_nivel2: razon\n    }\n  };\n});"
      },
