    {
      "parameters": {
        "jsCode": "// CAPA 1 — VALIDACIÓN DE FIRMA HMAC\n// TODO Bloque 7: implementar validación real del header X-Webhook-Signature\n\n// Función de sanitización: escapa comillas simples para queries PostgreSQL\nconst sanitizeStr = (val) => {\n  if (val === null || val === undefined) return '';\n  return typeof val === 'string' ? val.replace(/'/g, \"''\") : String(val);\n};\n\nconst items = $input.all();\n\nreturn items.map(item => {\n  const body = item.json.body || item.json;\n  \n  return {\n    json: {\n      ...item.json,\n      body: {\n        nome:          sanitizeStr(body.nome),\n        cognome:       sanitizeStr(body.cognome),\n        email:         body.email?.toLowerCase().trim() || null,\n        azienda:       sanitizeStr(body.azienda),\n        servizio:      sanitizeStr(body.servizio),\n        messaggio:     sanitizeStr(body.messaggio),\n        timestamp_roma: sanitizeStr(body.timestamp_roma)\n      }\n    }\n  };\n});"
      },
